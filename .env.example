# PostgreSQL
POSTGRES_USER=lhlogging
POSTGRES_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432
DB_NAME=lhlogging

# OpenSky Network (OAuth2 — find clientId/clientSecret in your account settings)
OPENSKY_CLIENT_ID=your_client_id
OPENSKY_CLIENT_SECRET=your_client_secret
OPENSKY_BASE_URL=https://opensky-network.org/api
# OPENSKY_TOKEN_URL=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token

# Planespotters
PLANESPOTTERS_BASE_URL=https://api.planespotters.net/pub/flights
PLANESPOTTERS_AIRLINE_ICAO=DLH
# Callsign prefix for live discovery (e.g. DLH = Lufthansa flights)
AIRLINE_CALLSIGN_PREFIX=DLH
# Comma-separated registration prefixes — aircraft matching these are included even if
# their operatoricao field is blank/wrong in the OpenSky CSV (e.g. D-A covers all LH mainline)
AIRLINE_REGISTRATION_PREFIXES=D-A

# Aircraft type filter — comma-separated ICAO type codes to track (empty = track all)
# LH widebodies: A332,A333,A343,A345,A346,A359,A35K,A388,B744,B748,B788,B789
# Leave empty to track all active Lufthansa aircraft:
TRACK_AIRCRAFT_TYPES=

# FlightAware AeroAPI (optional — used by tools/eval_flightaware.py)
FLIGHTAWARE_API_KEY=your_flightaware_api_key

# Tuning
OPENSKY_REQUEST_DELAY_S=2.0
OPENSKY_RATELIMIT_BACKOFF_S=60
OPENSKY_LOOKBACK_HOURS=26
FLIGHT_DETECT_LOOKBACK_MINUTES=90
PLANESPOTTERS_REQUEST_DELAY_S=1.0
BATCH_MAX_ERRORS_BEFORE_ABORT=50

# Admin interface — set to a random string to enable (e.g. admin-a8f3e2b1)
# The admin page will be available at /<this value>/ on the dashboard
# Leave empty to disable admin routes
# In production, protect with Caddy basic_auth on the same path prefix:
#   handle /<prefix>/* {
#     basic_auth { admin <caddy hash-password output> }
#     reverse_proxy localhost:8080
#   }
ADMIN_PATH_PREFIX=

# Logging
LOG_DIR=/var/log/lhlogging
LOG_LEVEL=INFO
